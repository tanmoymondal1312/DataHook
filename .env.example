# ---------------------------------------------------------------------------
# DataHook environment configuration. Copy to `.env` and edit for your setup.
#   cp .env.example .env
# ---------------------------------------------------------------------------

# Django core -----------------------------------------------------------------
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,datahook.mediaghor.com

# Public base URL used to build ingest URLs and code snippets (no trailing slash)
BASE_URL=http://localhost:8000
# In production:
# BASE_URL=https://datahook.mediaghor.com

# JWT lifetimes ---------------------------------------------------------------
ACCESS_TOKEN_LIFETIME_MIN=60
REFRESH_TOKEN_LIFETIME_DAYS=14

# CORS ------------------------------------------------------------------------
# Governs the ADMIN API (/api/) only — the Android client's origins. The public
# /ingest/ endpoint always allows all origins (handled by IngestCorsMiddleware),
# so plain HTML forms and apps from any site can post regardless of these.
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://datahook.mediaghor.com

# Throttling (DRF rates) ------------------------------------------------------
INGEST_THROTTLE_RATE=60/minute
AUTH_THROTTLE_RATE=20/minute

# Firebase / FCM --------------------------------------------------------------
# Absolute path to your Firebase service-account JSON. Leave blank to disable
# push notifications (the rest of the API keeps working).
FIREBASE_CREDENTIALS=/etc/datahook/firebase-service-account.json

# Timezone --------------------------------------------------------------------
TIME_ZONE=UTC

# Postgres (optional) — set POSTGRES_DB to switch from SQLite to Postgres ------
# POSTGRES_DB=datahook
# POSTGRES_USER=datahook
# POSTGRES_PASSWORD=supersecret
# POSTGRES_HOST=127.0.0.1
# POSTGRES_PORT=5432
